# SNITCH — Monad wallet-forensics graph. Copy to .env.local for `vercel dev`,
# and set these in the Vercel project settings for production. NEVER commit real values.

# Free Etherscan key — works across all Etherscan V2 chains incl. Monad mainnet (143).
# Create one at https://etherscan.io/apis
ETHERSCAN_API_KEY=

# Optional. Defaults to the public Monad mainnet RPC if unset.
MONAD_RPC=https://rpc.monad.xyz

# Optional 24h cache. Without these the API still works, just uncached.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
