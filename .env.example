# SNITCH — Monad wallet-forensics graph. Copy to .env.local for `vercel dev`,
# and set these in the Vercel project settings for production. NEVER commit real values.

# Free Etherscan key — works across all Etherscan V2 chains incl. Monad mainnet (143).
# Create one at https://etherscan.io/apis
ETHERSCAN_API_KEY=

# Optional. Defaults to the public Monad mainnet RPC if unset.
MONAD_RPC=https://rpc.monad.xyz

# Optional 24h cache. Without these the API still works, just uncached.
# (also required by $CHRONIC GROW below — the game uses them as its database)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ───────────────────────── $CHRONIC GROW (game) ─────────────────────────
# Solana RPC — set to YOUR Alchemy Solana URL. Stays server-side only; the
# browser reaches it through /api/solrpc so the key never ships to the client.
SOLANA_RPC=https://solana-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# The live $CHRONIC SPL token (override only if it ever changes).
CHRONIC_MINT=J5vR9wAwQEx29KNwSnv5hUx9gDyNeRZZE9XDEQeBpump
CHRONIC_DECIMALS=6

# The pool wallet's $CHRONIC associated token account — the 40% lands here and
# payouts are sent from here. Burner now, your wallet later (see GROW-BACKEND.md).
POOL_TOKEN_ACCOUNT=

# ── settle script only (tools/), NOT for Vercel — keep this key offline ──
# base58 string OR JSON array of the pool wallet's 64-byte secret key.
POOL_SECRET_KEY=
