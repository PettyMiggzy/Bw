# $CHRONIC — Solana. Copy to .env.local for `vercel dev`, and set these in the
# Vercel project settings for production. NEVER commit real values.

# Supabase — the $CHRONIC GROW database + terminal caches (24h TTL). Without
# these the cached endpoints still work, just uncached.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ───────────────────────── $CHRONIC GROW (game) ─────────────────────────
# Solana RPC — set to YOUR Alchemy Solana URL. Stays server-side only; the
# browser reaches it through /api/solrpc so the key never ships to the client.
SOLANA_RPC=https://solana-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# The live $CHRONIC SPL token (override only if it ever changes).
CHRONIC_MINT=J5vR9wAwQEx29KNwSnv5hUx9gDyNeRZZE9XDEQeBpump
CHRONIC_DECIMALS=6

# The pool wallet ADDRESS (plain address — not a token account). The 40% lands
# in its $CHRONIC token account and payouts are sent from there. Burner now,
# your wallet later (see GROW-BACKEND.md).
POOL_WALLET=

# ───────────────────── Fiat on/off ramp (MoonPay) ─────────────────────
# MoonPay is the licensed party (KYC + card/bank). We only hand it a SIGNED,
# pre-filled widget URL via /api/moonpay — we never touch fiat or custody.
# Get keys: MoonPay dashboard after KYB on your entity. Until set, the card
# buttons show a friendly "unlocks soon" message and nothing breaks.
MOONPAY_KEY=          # publishable key  pk_test_… (sandbox) / pk_live_…
MOONPAY_SECRET=       # secret key       sk_test_… / sk_live_…  — server only, NEVER ship
MOONPAY_ENV=sandbox   # 'sandbox' until KYB clears, then 'live'

# ── Seedless embedded wallet (Privy) — PUBLIC app id, safe in client code ──
# Privy dashboard → App settings. Used by /wallet (email-in, wallet-out, no
# seed phrase). Inject as window.PRIVY_APP_ID or hard-set in wallet.html.
PRIVY_APP_ID=

# ── settle script only (tools/), NOT for Vercel — keep this key offline ──
# base58 string OR JSON array of the pool wallet's 64-byte secret key.
POOL_SECRET_KEY=

# ── OPTIONAL future ops fee (currently OFF — game is 100% burn/pool) ──
# Dev wallet on file for if you ever turn on a small per-buy SOL fee.
# Nothing reads these yet; enabling requires a small code change + honest copy.
# DEV_WALLET=E7Cr2nad1SvBWF8vcGhNW575UVVPdTcgHEqSTMQzoUr5
# OPS_FEE_SOL=0

# ── X auto-poster (tools/poster.js + GitHub Action; NOT for Vercel) ──
# X (Twitter) developer app keys with write access (OAuth 1.0a user context).
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
# thresholds (whole $CHRONIC)
POST_BURN_THRESHOLD=500000
POOL_STEP=500000
